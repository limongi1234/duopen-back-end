# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGc...

# ── PostgreSQL direto (SQLAlchemy async) ──────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=15
REFRESH_TOKEN_EXPIRE=10080

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── IA Generativa / RAG (stack gratuita) ──────────────────────
# LLM: Gemini via Google AI Studio (aistudio.google.com) — 1M tokens/dia grátis
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite
# Embeddings locais (HuggingFace, 384 dims — casa com VECTOR(384) no banco)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=5
RAG_TEMPERATURE=0.3

# ── Aplicação ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
CORS_ORIGINS=
